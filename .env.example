# =============================================================================
# CREDO Finanzportal - Umgebungsvariablen
# =============================================================================
# Kopieren als .env.production und Werte anpassen

# ── Datenbank ────────────────────────────────────────────
DB_PASSWORD=change-me-strong-password

# ── Verschlüsselung (für E-Mail-Credentials im AdminCenter) ─
ENCRYPTION_KEY=change-me-32-character-secret-key!

# ── E-Mail-Versand (SMTP) ───────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=finanzportal@credo.de
SMTP_PASS=change-me

# ── Absender ─────────────────────────────────────────────
MAIL_FROM_NAME=CREDO Finanzportal
MAIL_FROM_EMAIL=finanzportal@credo.de

# ── Admin ────────────────────────────────────────────────
ADMIN_INITIAL_PASSWORD=change-me-admin

# ── App ──────────────────────────────────────────────────
APP_URL=https://finance.fes-credo.de
